# ─────────────────────────────────────────────────────────────
# OpenAI(ChatGPT) API 설정
# 이 파일을 복사해 .env.local 로 만들고 값을 채워주세요.
#   cp .env.example .env.local
# .env.local 은 git 에 절대 커밋되지 않습니다(.gitignore 처리됨).
# ─────────────────────────────────────────────────────────────

# OpenAI API Key (서버에서만 사용, 프론트엔드에 노출되지 않음)
OPENAI_API_KEY=

# 사용할 모델명. 코드에 하드코딩하지 않고 이 값을 우선 사용합니다.
# 값이 없으면 코드 기본값(gpt-5.5)을 사용합니다.
OPENAI_MODEL=gpt-5.5

# 포메이션 채팅이 연결되는 ChatGPT 프로젝트(채팅방) URL.
# 화면에 "이 채팅방에 연결됨" 링크로 표시됩니다.
# (참고: OpenAI API 는 ChatGPT.com 프로젝트에 직접 저장하는 기능을 제공하지 않습니다.
#  자세한 내용은 README 의 'ChatGPT 채팅방 연동' 섹션을 확인하세요.)
NEXT_PUBLIC_OPENAI_PROJECT_URL=https://chatgpt.com/g/g-p-6a39d5a260d481918b5c48d28d40cc3d-hapeosebeun/project
